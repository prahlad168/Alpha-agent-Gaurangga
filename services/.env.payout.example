# ================================================
# MAHA-LAKSHMI-CORP: Payout Service Configuration
# ================================================
# COPY THIS FILE TO .env.payout AND FILL IN YOUR KEYS
# IMPORTANT: Add .env.payout to .gitignore!
# ================================================

# ================================================
# MODE CONFIGURATION
# ================================================

# Set to 'true' for simulation mode (no actual transfers)
# Set to 'false' for LIVE disbursement
SIMULATION_MODE=true

# API Provider: 'flip' or 'midtrans'
PAYOUT_PROVIDER=flip

# ================================================
# FLIP FOR BUSINESS (RECOMMENDED)
# ================================================
# Get your API key from: https://dashboard.flip.id
# 
FLIP_SECRET_KEY=YOUR_FLIP_SECRET_KEY_HERE

# ================================================
# MIDTRANS PAYOUTS (ALTERNATIVE)
# ================================================
# Get your keys from: https://dashboard.midtrans.com
#
MIDTRANS_MERCHANT_ID=YOUR_MERCHANT_ID
MIDTRANS_SERVER_KEY=YOUR_SERVER_KEY_HERE
MIDTRANS_CLIENT_KEY=YOUR_CLIENT_KEY
MIDTRANS_ENV=sandbox

