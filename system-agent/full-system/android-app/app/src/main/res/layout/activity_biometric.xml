<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a"
    android:padding="32dp">

    <!-- GAURANGA Logo -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/ic_gauranga_logo"
        android:contentDescription="GAURANGA Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖 GAURANGA"
        android:textColor="#ffffff"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/logoImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Agent Alpha v1.0"
        android:textColor="#888888"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Biometric Icon -->
    <ImageView
        android:id="@+id/biometricIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_fingerprint"
        android:contentDescription="Fingerprint"
        app:tint="#6366f1"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/subtitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Status Text -->
    <TextView
        android:id="@+id/biometricStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔐 Biometric Authentication Required\n\nGunakan Fingerprint untuk verifikasi identitas\nOwner: I Made Purna Ananda"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/biometricIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Authenticate Button -->
    <Button
        android:id="@+id/authenticateButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🔐 Authenticate with Fingerprint"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#6366f1"
        app:cornerRadius="28dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/biometricStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Skip Button (for testing) -->
    <Button
        android:id="@+id/skipButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Skip (Demo Only)"
        android:textColor="#888888"
        android:textSize="14sp"
        android:background="@android:color/transparent"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/authenticateButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Owner Info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👑 MAHA LAKSHMI HOLDINGS"
        android:textColor="#666666"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>